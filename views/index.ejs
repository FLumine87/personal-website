<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - My Personal Website</title>
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
        })();
    </script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="home-page">
    <button id="theme-toggle" class="theme-toggle fixed-position" aria-label="Toggle dark/light theme">
        <img class="theme-icon sun-icon" src="/images/sun.svg" alt="Light mode" width="20" height="20">
        <img class="theme-icon moon-icon" src="/images/moon.svg" alt="Dark mode" width="20" height="20">
    </button>

    <main>
        <div class="hero-section">
            <h1>Welcome to My Personal Website</h1>
            <p class="hero-subtitle">A Computing Science student at the University of Aberdeen</p>
            <div class="hero-nav">
                <a href="/about" class="btn btn-primary">About Me</a>
                <a href="/game" class="btn btn-secondary">Play Game</a>
            </div>
        </div>
        
        <div class="container">
            <section>
                <h2>About Me</h2>
                <p>Hello! I'm a Computing Science student at the University of Aberdeen, currently in my second year.</p>
                <p>This website is my coursework project for <strong>JC2503 Web Application Development</strong>. It demonstrates my skills in HTML5, CSS3, Node.js, Express, and Socket.IO.</p>
                <p>The site features a personal introduction, an about page highlighting my academic interests, and a fully functional multiplayer puzzle game.</p>
                <div class="mt-2">
                    <a href="/game" class="btn">Play the Game →</a>
                </div>

                <h3>Quick Facts</h3>
                <ul>
                    <li>🎓 Studying: Computing Science</li>
                    <li>📍 Based in: China / Aberdeen</li>
                    <li>💻 Interested in: Web Dev, Game Dev, AI</li>
                    <li>🎮 Hobbies: Coding, Chess, Hiking</li>
                </ul>
                <h3>Course Info</h3>
                <p>JC2503 - Web Application Development<br>University of Aberdeen</p>
            </section>
        </div>
    </main>

    <footer>
        <p>© 2025 Gu Hao - JC2503 Coursework Assignment</p>
    </footer>

    <script>
        // Theme toggle functionality
        function initThemeToggle() {
            const themeToggle = document.getElementById('theme-toggle');
            
            // Check localStorage first, default to light theme
            const savedTheme = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-theme', savedTheme);
            
            // Toggle theme on button click
            themeToggle?.addEventListener('click', () => {
                const currentTheme = document.documentElement.getAttribute('data-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                
                document.documentElement.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
            });
        }
        
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initThemeToggle);
        } else {
            initThemeToggle();
        }
    </script>
</body>
</html>